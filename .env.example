# Vault backup queue poller — off by default. Calls the vault-backup-worker-tick
# edge function on an interval using the WORKER_SECRET above. Foundation phase
# only: claims queued items and moves them to "preparing", no download/upload yet.
VAULT_BACKUP_WORKER_ENABLED=false
VAULT_BACKUP_POLL_INTERVAL_SECONDS=30
