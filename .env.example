SUPABASE_URL=https://xshkaaabvmjokfsfajvj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here
WORKER_SECRET=generate_a_random_string_here
PORT=3000

# Vault backup queue poller — off by default. Calls the vault-backup-worker-tick
# edge function on an interval using the WORKER_SECRET above; that endpoint only
# claims one queued item and marks it "preparing". This service does everything
# after that — dry-run simulation or (see VAULT_BACKUP_DRY_RUN below) a real
# yt-dlp download + Backblaze B2 upload.
VAULT_BACKUP_WORKER_ENABLED=false
VAULT_BACKUP_POLL_INTERVAL_SECONDS=30

# true (default, or unset): simulates preparing -> downloading -> uploading ->
# verifying -> completed with no real file transfer. false: real transfer —
# yt-dlp downloads the video, ffprobe validates it, and (for Arşiv storage
# mode) the file is uploaded to Backblaze B2. Streaming-mode (İzlenebilir)
# videos are downloaded + validated then left at ready_for_streaming_upload —
# Bunny upload isn't implemented yet. Sadece Yerel videos are never downloaded.
VAULT_BACKUP_DRY_RUN=true

# Backblaze B2 — S3-compatible API, private bucket "dugunhub-vault-originals".
# Scoped application key, not the account master key. Never hardcode these;
# never generate/return a public or signed URL for anything uploaded here.
BACKBLAZE_KEY_ID=your_b2_key_id_here
BACKBLAZE_APPLICATION_KEY=your_b2_application_key_here
BACKBLAZE_BUCKET=dugunhub-vault-originals
BACKBLAZE_ENDPOINT=s3.eu-central-003.backblazeb2.com
